# Frontend runtime configuration. Copy to `.env.local` and adjust for your machine.
# Vite only exposes vars prefixed with VITE_ to the browser bundle.

# Base URL of the gateway (REST via axios + Socket.IO via socket.io-client).
# The frontend talks ONLY to the gateway, never to ai_service directly.
# Gateway listens on :4000 by default (see backend/gateway config PORT).
VITE_GATEWAY_URL=http://localhost:4000

# Mock mode. Defaults to true when unset (see src/lib/env.ts): the app runs fully
# against in-memory mock data and getSocket() returns null (no live socket).
# Set to 'false' to hit the real gateway for REST *and* open the live Socket.IO
# connection — required for the two-window `?as=N` live group-chat demo.
VITE_USE_MOCK=false

# Geoapify API key for the host session "Where should we meet?" location
# autocomplete. Free tier (3,000 req/day, no credit card): sign up at
# geoapify.com, create a project, and restrict the key by allowed origin to your
# domain(s). Safe to expose in the browser bundle. When blank, the location field
# degrades to plain free-text entry with the existing server-side geocode
# validation (no autocomplete suggestions).
VITE_GEOAPIFY_API_KEY=
