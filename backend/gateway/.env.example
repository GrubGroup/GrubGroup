# --- Server ---
PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- Auth (Better Auth) ---
# Secret used to sign/encrypt sessions. Use a long random value (>= 32 chars).
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
# Public base URL of THIS gateway — OAuth callbacks resolve against it.
BETTER_AUTH_URL=http://localhost:5173
# Google OAuth credentials (server-side code-exchange flow — both required).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Downstream services ---
AI_SERVICE_URL=http://localhost:8000

# --- External APIs ---
# Geocodio API key — turns a member's address into lat/lon at write time.
# Optional: if unset, addresses save with null coordinates (no hard failure).
GEOCODIO_API=

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grubgroup
