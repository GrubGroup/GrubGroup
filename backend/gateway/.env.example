# --- Server ---
PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- Auth ---
# Secret used to mint/verify JWTs. Must match the ai_service JWT_SECRET.
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# --- Downstream services ---
AI_SERVICE_URL=http://localhost:8000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grubgroup
