// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  // postgresqlExtensions lets Prisma manage the `vector` extension (datasource below).
  previewFeatures = ["postgresqlExtensions"]
  // Emit into the gateway — the only service that runs the Prisma client (auth).
  // ai_service uses SQLModel, not Prisma. Path is relative to this schema file
  // (backend/gateway/prisma/), so ../node_modules resolves to gateway/node_modules.
  output          = "../node_modules/.prisma/client"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum Role {
  USER
  OWNER
  ADMIN
}

enum MessageType {
  TEXT
  IMG
  SYSTEM
  SESSION_BLOCK
}

model User {
  // -- Fields (columns) --
  id              Int      @id @default(autoincrement())
  username        String   @unique
  email           String   @unique
  role            Role     @default(USER)
  display_name    String?
  avatar_url      String?
  // -- Auth (Better Auth) --
  emailVerified   Boolean  @default(false)
  displayUsername String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // -- Relations (virtual, no columns) --
  profile             Profile?
  hosted_sessions     Session[]       @relation("SessionHost")
  session_memberships SessionMember[]
  events              Event[]         @relation("EventAttendees")
  group_memberships   GroupMember[]
  group_messages      GroupMessage[]
  auth_sessions       AuthSession[]
  accounts            Account[]
  qas                 Qa[]
}

model Profile {
  // -- Fields (columns) --
  id                   Int      @id @default(autoincrement())
  user_id              Int      @unique
  dietary_restrictions String[]
  disliked_cuisines    String[]
  preferred_cuisines   String[]
  budget_min           Int
  budget_max           Int
  // Durable default dining location. `default_address` is the address label the
  // profile UI shows; lat/lon (optional) let a session's Qa inherit precise
  // coordinates without re-geocoding when the member doesn't override location.
  // `default_radius` is the preferred search radius in miles around the address.
  default_address      String?
  default_lat          Float?
  default_lon          Float?
  default_radius       Float?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  liked_restaurant_ids Int[]

  // -- Relations (virtual, no columns) --
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Session {
  // -- Fields (columns) --
  id            Int       @id @default(autoincrement())
  host_user_id  Int
  group_id      Int? // originating group; server reads this to stamp the Event
  time_limit    Int
  // The host's chosen event time (from the pre-session modal): "Now" -> now() at
  // create, or a custom Day+hh:mm. Drives restaurant open/closed evaluation and
  // is snapshotted onto Event.date at session close. Replaces the removed host
  // Qa.time_slot free-text field with a real datetime.
  scheduled_for DateTime?
  created_at    DateTime  @default(now())
  closed_at     DateTime?
  // NOTE: no avg_budget column. The averaged group budget is computed on demand
  // (mean of members' effective budget_max) by the ai_service orchestrator and
  // is never persisted — see orchestrator_agent._reconcile.

  // -- Relations (virtual, no columns) --
  host            User             @relation("SessionHost", fields: [host_user_id], references: [id])
  group           Group?           @relation(fields: [group_id], references: [id], onDelete: Cascade)
  members         SessionMember[]
  qas             Qa[]             @relation("SessionQas")
  recommendations Recommendation[]
}

// Join model: one row per (user joined a session). Carries per-member status.

model SessionMember {
  // -- Fields (columns) --
  session_id Int
  user_id    Int
  status     Boolean  @default(false) // was Session.members_status — now per-member
  joined_at  DateTime @default(now())

  // -- Relations (virtual, no columns) --
  session Session @relation(fields: [session_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([session_id, user_id])
}

model Event {
  // -- Fields (columns) --
  id              Int      @id @default(autoincrement())
  date            DateTime
  address         String
  // Geocoded coordinates of the host's chosen location, snapshotted from the
  // host's Qa row at close (nullable: a geocode miss leaves them null).
  lat             Float?
  lon             Float?
  restaurant_id   Int
  restaurant_name String
  occasion        String? // host-only; snapshot from the host's Qa row at close
  time_slot       String? // host-only display label; snapshot from the host's Qa row at close
  group_id        Int?
  group_name      String? // snapshot of Group.name at creation; persists after group deletion

  // -- Relations (virtual, no columns) --
  restaurant Restaurant @relation(fields: [restaurant_id], references: [id])
  attendees  User[]     @relation("EventAttendees")
  group      Group?     @relation(fields: [group_id], references: [id], onDelete: SetNull)
}

model Restaurant {
  // -- Fields (columns) --
  id           Int                          @id @default(autoincrement())
  name         String
  description  String?
  cuisine_tags String[]
  dietary_tags String[]
  price_avg    Float?
  address      String?
  lat          Float?
  long         Float?
  hours        String?
  created_at   DateTime                     @default(now())
  updated_at   DateTime                     @updatedAt
  avg_rating   Float?
  embedding    Unsupported("vector(1024)")?

  // -- Relations (virtual, no columns) --
  events               Event[]
  recommendation_items RecommendationItem[]
}

model Qa {
  // -- Fields (columns) --
  // One row per (session, member): each member's TEMPORARY, session-scoped
  // preference overrides captured by their QA sub-agent. These outrank the
  // durable Profile for this session only and are deleted when the Event is
  // created. occasion is HOST-ONLY (the host_user_id row) — a non-host's row
  // leaves it null. The host's chosen event TIME is no longer a Qa field: it
  // lives on Session.scheduled_for (a real datetime). location_* are per-member:
  // the host's row carries the group's primary location; each member may add a
  // preferred (closer-to-them) location the orchestrator weights as a secondary
  // anchor.
  id                 Int      @id @default(autoincrement())
  session_id         Int
  user_id            Int
  preferred_cuisines String[]
  disliked_cuisines  String[]
  occasion           String? // host-only
  location_mode      String?
  location_address   String? // free-text address the member entered; geocoded into location_lat/lon
  location_lat       Float?
  location_lon       Float?
  radius_miles       Float?
  budget_min         Int?
  budget_max         Int?
  member_status      String?

  // -- Relations (virtual, no columns) --
  session Session @relation("SessionQas", fields: [session_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // One Qa row per member per session (get-or-create keys on this).
  @@unique([session_id, user_id])
}

model Group {
  // -- Fields (columns) --
  id         Int       @id @default(autoincrement())
  created_at DateTime  @default(now())
  closed_at  DateTime?
  name       String

  // -- Relations (virtual, no columns) --
  members  GroupMember[]
  messages GroupMessage[]
  events   Event[]
  sessions Session[]
}

// Join model: one row per (user in a group).

model GroupMember {
  // -- Fields (columns) --
  group_id  Int
  user_id   Int
  joined_at DateTime @default(now())

  // -- Relations (virtual, no columns) --
  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([group_id, user_id])
}

model GroupMessage {
  // -- Fields (columns) --
  id           Int         @id @default(autoincrement())
  group_id     Int
  user_id      Int
  content      String
  message_type MessageType @default(TEXT)
  created_at   DateTime    @default(now())

  // -- Relations (virtual, no columns) --
  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id])
}

model Recommendation {
  // -- Fields (columns) --
  id         Int      @id @default(autoincrement())
  session_id Int
  created_at DateTime @default(now())

  // -- Relations (virtual, no columns) --
  session Session              @relation(fields: [session_id], references: [id], onDelete: Cascade)
  items   RecommendationItem[]
}

// Join model: one row per recommended restaurant, carrying its score + justification.

model RecommendationItem {
  // -- Fields (columns) --
  id                Int     @id @default(autoincrement())
  recommendation_id Int
  restaurant_id     Int
  match_score       Float?
  justification     String?

  // -- Relations (virtual, no columns) --
  recommendation Recommendation @relation(fields: [recommendation_id], references: [id], onDelete: Cascade)
  restaurant     Restaurant     @relation(fields: [restaurant_id], references: [id])
}

model AuthSession {
  id        Int      @id @default(autoincrement())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("AuthSession")
}

model Account {
  id                    Int       @id @default(autoincrement())
  accountId             String
  providerId            String
  userId                Int
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         Int      @id @default(autoincrement())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
