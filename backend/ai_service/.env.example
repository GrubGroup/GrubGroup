# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/grubgroup

# --- LLM chat (Salesforce internal model gateway, OpenAI-compatible) ---
SALESFORCE_API_KEY=
SALESFORCE_LLM_MODEL=
SALESFORCE_BASE_URL=

# --- Embeddings (ACTIVE: OpenRouter / Qwen) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# --- LLM chat (DEPLOYMENT fallback: OpenRouter/DeepSeek) ---
# Uncomment the OpenRouter block in app/ai/llm/client.py to route chat here, and
# set the model below (it feeds settings.llm_model when SALESFORCE_LLM_MODEL is unset).
# LLM_MODEL=deepseek/deepseek-chat

# --- Geocoding (Geocodio) ---
# Turns a member's named location into lat/lon on the conversational analyze
# path. Optional: if unset, locations save with null coordinates (no failure).
# Accepts GEOCODIO_API_KEY or the gateway's GEOCODIO_API name.
GEOCODIO_API_KEY=

# --- Voice ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=

# --- App ---
ENV=development
LOG_LEVEL=info
