# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/grubgroup

# --- Auth ---
# Shared secret used to verify JWTs minted by the gateway service.
JWT_SECRET=change-me
JWT_ALGORITHM=HS256

# --- LLM / RAG (via OpenRouter) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat
# Embedding model served via OpenRouter's OpenAI-compatible /embeddings API.
# Native dim is 4096; the service requests dimensions=1024 to match vector(1024).
EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# --- Voice ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=

# --- App ---
ENV=development
LOG_LEVEL=info
