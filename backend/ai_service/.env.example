# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/grubgroup

# --- LLM chat provider switch ---
# Selects which chat client app/ai/llm/client.py builds — no code edit needed.
#   salesforce → Salesforce internal model gateway (Claude), for local dev
#   openrouter → OpenRouter/DeepSeek (default), for deploy
# Leave unset on deploy (defaults to openrouter); set to salesforce locally.
LLM_PROVIDER=openrouter

# --- LLM chat (Salesforce internal model gateway, OpenAI-compatible) ---
# Used when LLM_PROVIDER=salesforce. BASE_URL + LLM_MODEL have config defaults;
# set at least the API key. TLS verifies against NODE_EXTRA_CA_CERTS when set.
SALESFORCE_API_KEY=
SALESFORCE_LLM_MODEL=
SALESFORCE_BASE_URL=
# NODE_EXTRA_CA_CERTS=/path/to/corporate-ca-bundle.pem

# --- Embeddings (ALWAYS OpenRouter / Qwen) + OpenRouter chat ---
# OPENROUTER_* also serve chat when LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
# OpenRouter chat model (feeds settings.active_llm_model when LLM_PROVIDER=openrouter).
LLM_MODEL=ddeepseek/deepseek-v4-flash

# --- Geocoding (Geocodio) ---
# Turns a member's named location into lat/lon on the conversational analyze
# path. Optional: if unset, locations save with null coordinates (no failure).
# Accepts GEOCODIO_API_KEY or the gateway's GEOCODIO_API name.
GEOCODIO_API_KEY=

# --- Voice ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=

# --- App ---
ENV=development
LOG_LEVEL=info
